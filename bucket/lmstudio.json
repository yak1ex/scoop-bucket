{
    "version": "0.4.15-2",
    "description": "Discover, download, and run local LLMs",
    "homepage": "https://lmstudio.ai/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://lmstudio.ai/terms"
    },
    "architecture": {
        "64bit": {
            "url": "https://installers.lmstudio.ai/win32/x64/0.4.15-2/LM-Studio-0.4.15-2-x64.exe#/dl.7z",
            "hash": "7d938436f312e04d4f9036c011aaf4e3cf2d2ddb52032aff251b051e8624b4c5",
            "installer": {
                "script": [
                    "Remove-Item \"$dir\\*\" -Exclude \"app-64.7z\"",
                    "Expand-7zipArchive \"$dir\\app-64.7z\" \"$dir\"",
                    "Remove-Item \"$dir\\app-64.7z\""
                ]
            }
        },
        "arm64": {
            "url": "https://installers.lmstudio.ai/win32/arm64/0.4.15-2/LM-Studio-0.4.15-2-arm64.exe#/dl.7z",
            "hash": "244a7e8e25e865964d84555569b600ec7233dbb1518db5c60c685acc67fd643d",
            "installer": {
                "script": [
                    "Remove-Item \"$dir\\*\" -Exclude \"app-arm64.7z\"",
                    "Expand-7zipArchive \"$dir\\app-arm64.7z\" \"$dir\"",
                    "Remove-Item \"$dir\\app-arm64.7z\""
                ]
            }
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "shortcuts": [
        [
            "LM Studio.exe",
            "LM Studio"
        ]
    ],
    "checkver": {
        "url": "https://lmstudio.ai/download",
        "regex": "\\\\\"version\\\\\":\\\\\"(?<ver>[\\d.]+)\\\\\",\\\\\"build\\\\\":\\\\\"(?<build>\\d+)\\\\\"",
        "replace": "${ver}-${build}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://installers.lmstudio.ai/win32/x64/$version/LM-Studio-$version-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://installers.lmstudio.ai/win32/arm64/$version/LM-Studio-$version-arm64.exe#/dl.7z"
            }
        }
    }
}
