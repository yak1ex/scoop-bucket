                    "    Start-Process -Wait -WindowStyle Hidden \"$dir\\Win32\\TeraCopy.exe\" Test",
                    "}"
                ]
            },
            "shortcuts": [
                [
                    "Win32\\TeraCopy.exe",
                    "TeraCopy"
